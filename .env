# Database Connection String
# Format: postgres://<user>:<password>@<host>:<port>/<dbname>?sslmode=disable
DATABASE_URL=postgres://postgres:@127.0.0.1:5432/serialization?search_path=public&sslmode=disable

# Server Configuration
PORT=8080
ENVIRONMENT=development

# Batch Settings (Optional, if you want to make them configurable)
MAX_BATCH_SIZE=5000